# ========================================
# Configuración del Agente Conversacional
# ========================================
# Proveedor de LLM (ejemplo: 'ollama', 'azure', 'openai')
LLM_PROVIDER=ollama

# Modelo a usar (depende del provider)
LLM_MODEL=qwen3.5:9b

# Host donde corre Ollama (defecto: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# Host donde corre Chroma (defecto: localhost:8000)
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Ruta al servidor MCP (si no se define, se usará la ruta por defecto en el código)
MCP_SERVER_PATH=/home/maro/proyectos/trabajo/agente-mcp-ollama/libs/mcp/src/lib/server.js

# api config
API_HOST=localhost
API_PORT=3333